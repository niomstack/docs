{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "NIOM",
  "colors": {
    "primary": "#5B3FE6",
    "light": "#7c6aff",
    "dark": "#5B3FE6"
  },
  "favicon": "/niom-logo.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "configuration"
            ]
          },
          {
            "group": "Core Features",
            "pages": [
              "guides/memory",
              "guides/skill-routing",
              "guides/background-tasks",
              "guides/tools",
              "guides/project-awareness"
            ]
          },
          {
            "group": "Advanced",
            "pages": [
              "guides/keyboard-shortcuts",
              "guides/ollama",
              "guides/privacy"
            ]
          }
        ]
      },
      {
        "tab": "Architecture",
        "groups": [
          {
            "group": "System Design",
            "pages": [
              "architecture/overview",
              "architecture/context-engine",
              "architecture/skill-tree",
              "architecture/task-system"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/niomstack/niom",
          "icon": "github"
        },
        {
          "anchor": "Releases",
          "href": "https://github.com/niomstack/niom/releases",
          "icon": "download"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/niom-logo-text-light.svg",
    "dark": "/logo/niom-logo-text-dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/niomstack/niom"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Download",
      "href": "https://github.com/niomstack/niom/releases"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/niomstack/niom",
      "x": "https://x.com/niomdev"
    }
  },
  "seo": {
    "indexHiddenPages": false
  },
  "background": {
    "style": "gradient"
  },
  "rounded": "default"
}